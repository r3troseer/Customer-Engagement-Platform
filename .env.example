# Copy this file to .env and fill in real values. Never commit .env.
# IMPORTANT: No inline comments on value lines — pydantic-settings will parse them as part of the value.

# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME="Customer Engagement Platform"
# development | staging | production
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# ── Database ─────────────────────────────────────────────────────────────────
# Async URL used by the FastAPI app (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/cep_db
# Sync URL used by Alembic migrations only (psycopg2 driver)
DATABASE_SYNC_URL=postgresql+psycopg2://postgres:password@localhost:5432/cep_db
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_ECHO=false

# ── Auth (JWT) ────────────────────────────────────────────────────────────────
# Secret is set by Omar (blockchain dev) — same value must be used across all services
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── File Storage ─────────────────────────────────────────────────────────────
# local | s3
STORAGE_BACKEND=s3
# Only used when STORAGE_BACKEND=local
LOCAL_UPLOAD_DIR=./uploads

# Railway Bucket (S3-compatible) — get these from Railway dashboard → Bucket → Connect
AWS_S3_BUCKET_NAME=
# Leave blank for AWS S3; set to Railway Bucket endpoint e.g. https://t3.storageapi.dev
AWS_ENDPOINT_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Railway uses "auto"; for AWS use e.g. eu-west-2
AWS_REGION=auto

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_NAME="CEP Platform"
EMAILS_FROM_EMAIL=noreply@cep-platform.com

# ── Push Notifications (FCM) ──────────────────────────────────────────────────
FCM_SERVER_KEY=

# ── Scheduler ────────────────────────────────────────────────────────────────
SCHEDULER_TIMEZONE=Europe/London
# Top N employees per org receive Monday bonus tokens
LEADERBOARD_TOP_N_BONUS=3

# ── Compliance Alert Thresholds ───────────────────────────────────────────────
CERT_EXPIRY_WARNING_DAYS=30
CERT_EXPIRY_CRITICAL_DAYS=7

# ── Pagination ────────────────────────────────────────────────────────────────
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
