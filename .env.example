# Copy this file to .env and fill in real values. Never commit .env.

# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME="Customer Engagement Platform"
APP_ENV=development          # development | staging | production
DEBUG=true
API_V1_PREFIX=/api/v1

# ── Database ─────────────────────────────────────────────────────────────────
# Async URL used by the FastAPI app (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/cep_db
# Sync URL used by Alembic migrations only (psycopg2 driver)
DATABASE_SYNC_URL=postgresql+psycopg2://postgres:password@localhost:5432/cep_db
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_ECHO=false

# ── Auth (JWT) ────────────────────────────────────────────────────────────────
# Secret is set by Omar (blockchain dev) — same value must be used across all services
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── File Storage ─────────────────────────────────────────────────────────────
STORAGE_BACKEND=local        # local | s3
LOCAL_UPLOAD_DIR=./uploads
# S3 / Railway Volume (set these if STORAGE_BACKEND=s3)
AWS_BUCKET_NAME=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-2

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_NAME="CEP Platform"
EMAILS_FROM_EMAIL=noreply@cep-platform.com

# ── Push Notifications (FCM) ──────────────────────────────────────────────────
FCM_SERVER_KEY=

# ── Scheduler ────────────────────────────────────────────────────────────────
SCHEDULER_TIMEZONE=Europe/London
LEADERBOARD_TOP_N_BONUS=3    # Top N employees get Monday bonus tokens

# ── Compliance Alert Thresholds ───────────────────────────────────────────────
CERT_EXPIRY_WARNING_DAYS=30
CERT_EXPIRY_CRITICAL_DAYS=7

# ── Pagination ────────────────────────────────────────────────────────────────
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
